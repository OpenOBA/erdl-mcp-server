# ERDL Rules — Coding
# Drop any .yaml file into ~/.openoba/rules/coding/
# Rules are loaded automatically. No restart needed.

rules:
  - id: CODING-101
    name: Example coding rule
    description: Replace with your own coding rules
    category: coding
    triggers: [write_code, output_code]
    conditions:
      - kind: intent_contains
        keywords: [typescript]
    action:
      decision: ALLOW
      instruction: Write clean, well-documented TypeScript code.
    priority: 100
    enabled: false
